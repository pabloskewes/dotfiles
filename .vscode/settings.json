{
  // ===================================================================
  // CORE EDITOR & WORKBENCH SETTINGS
  // ===================================================================
  "workbench.colorTheme": "Darcula",
  "editor.inlineSuggest.enabled": true,
  "editor.wordWrap": "on",
  "editor.formatOnSave": true,
  "explorer.confirmDragAndDrop": false,
  "terminal.integrated.enableMultiLinePasteWarning": "never",

  // ===================================================================
  // FILE ASSOCIATIONS & EDITOR ASSOCIATIONS
  // ===================================================================
  "files.associations": {
    "**/.ssh/config": "plaintext",
    "*.excalidraw": "json",
    "*.excalidrawlib": "json",
    "*.rmd": "markdown",
  },
  "workbench.editorAssociations": {
    "*.copilotmd": "vscode.markdown.preview.editor",
    "{git,gitlens}:/**/*.{md,csv}": "default",
    "*.md": "default",
  },

  // ===================================================================
  // LANGUAGE-SPECIFIC FORMATTERS
  // ===================================================================
  "[python]": {
    "editor.formatOnType": true,
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      // "source.fixAll": "explicit",
      "source.organizeImports": "explicit",
    },
    "python.languageServer": "None",
  },
  // Ruff extension settings - use project's ruff from .venv
  "ruff.executablePath": "${workspaceFolder}/.venv/bin/ruff",
  "ruff.enable": true,
  "ruff.organizeImports": true,
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "[c]": {
    "editor.defaultFormatter": "ms-vscode.cpptools",
  },
  "[cpp]": {
    "editor.defaultFormatter": "ms-vscode.cpptools",
  },
  "[typst]": {
    "editor.formatOnSave": true,
    "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>/?",
  },
  "[typst-code]": {
    "editor.wordSeparators": "`~!@#$%^&*()=+[{]}\\|;:'\",.<>/?",
  },
  "[dotenv]": {
    "editor.defaultFormatter": "foxundermoon.shell-format",
  },
  "[plaintext]": {
    "editor.formatOnSave": false,
    "editor.formatOnType": false,
    "editor.defaultFormatter": null,
  },
  "[dockerfile]": {
    "editor.defaultFormatter": null,
    "editor.formatOnSave": false,
  },
  "[toml]": {
    "editor.formatOnSave": false,
  },

  // ===================================================================
  // GIT SETTINGS
  // ===================================================================
  "git.enableSmartCommit": true,
  "git.confirmSync": false,

  // ===================================================================
  // GITHUB COPILOT SETTINGS
  // ===================================================================
  "github.copilot.enable": {
    "*": true,
    "plaintext": true,
    "markdown": true,
    "scminput": false,
    "yaml": true,
  },
  "github.copilot.advanced": {},
  "github.copilot.editor.enableAutoCompletions": true,
  "github.copilot.preferredAccount": "pabloskewes",

  // ===================================================================
  // CURSOR SETTINGS
  // ===================================================================
  "cursor.composer.shouldChimeAfterChatFinishes": true,
  "cursor.cpp.enablePartialAccepts": true,
  "cursor.general.globalCursorIgnoreList": [
    "",
    "",
    "**/credentials.json",
    "**/credentials.*.json",
    "**/secret.json",
    "**/secrets.json",
    "**/*.key",
    "**/*.pem",
    "**/*.pfx",
    "**/*.p12",
    "**/*.crt",
    "**/*.cer",
    "**/id_rsa",
    "**/id_dsa",
    "**/.ssh/id_*",
  ],
  // "cursorpyright.analysis.typeCheckingMode": "basic",

  // ===================================================================
  // OTHER EXTENSION SETTINGS
  // ===================================================================
  "excalidraw.theme": "dark",
  "markdown.extension.toc.updateOnSave": false,
  "tinymist.formatterMode": "typstyle",
  "prettier.disableLanguages": ["dockerfile"],
  "pylint.args": [
    "--disable=W1203", // Use lazy % formatting in logging functions
    "--disable=C0115", // Missing class docstring
    "--disable=C0116", // Missing function or method docstring
    "--disable=C0114", // Missing module docstring
  ],

  // ===================================================================
  // TOOL-SPECIFIC SETTINGS
  // ===================================================================
  "cmake.configureOnOpen": true,
  "cmake.options.statusBarVisibility": "icon",
  "cmake.pinnedCommands": [
    "workbench.action.tasks.configureTaskRunner",
    "workbench.action.tasks.runTask",
  ],
  "cmake.showOptionsMovedNotification": false,
  "makefile.configureOnOpen": true,
  "jupyter.askForKernelRestart": false,
  "liveshare.notebooks.allowGuestExecuteCells": true,
  "github.copilot.nextEditSuggestions.enabled": true,
  "cursor.composer.queueMessageDefaultBehavior": "stop-and-send",
  "cursor.composer.usageSummaryDisplay": "always",
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "gitlens.ai.model": "gemini:gemini-2.5-flash",
  "cursor.cpp.disabledLanguages": [],
}
