[
    {
        "key": "shift+enter",
        "command": "workbench.action.terminal.sendSequence",
        "when": "terminalFocus",
        "args": {
            "text": "\\\r\n"
        }
    },
    {
        "key": "ctrl+enter",
        "command": "workbench.action.terminal.sendSequence",
        "when": "terminalFocus",
        "args": {
            "text": "\\\r\n"
        }
    },
  // LaTeX-specific keybindings
  {
    "key": "cmd+b",
    "command": "editor.action.insertSnippet",
    "args": {
      "snippet": "\\textbf{${TM_SELECTED_TEXT:${1:\\<cursor-here>}}}"
    },
    "when": "editorTextFocus && !editorReadonly",
    "language": "latex"
  },
  {
    "key": "cmd+i",
    "command": "editor.action.insertSnippet",
    "args": {
      "snippet": "\\textit{${TM_SELECTED_TEXT:${1:\\<cursor-here>}}}"
    },
    "when": "editorTextFocus && !editorReadonly",
    "language": "latex"
  },
  {
    "key": "cmd+u",
    "command": "editor.action.insertSnippet",
    "args": {
      "snippet": "\\underline{${TM_SELECTED_TEXT:${1:\\<cursor-here>}}}"
    },
    "when": "editorTextFocus && !editorReadonly",
    "language": "latex"
  },
  {
    "key": "cmd+r",
    "command": "editor.action.insertSnippet",
    "args": {
      "snippet": "\\textcolor{red}{${TM_SELECTED_TEXT:${1:\\<cursor-here>}}}"
    },
    "when": "editorTextFocus && !editorReadonly",
    "language": "latex"
  },

  // Typst-specific keybindings
  {
    "key": "cmd+b",
    "command": "editor.action.insertSnippet",
    "args": {
      "snippet": "*${TM_SELECTED_TEXT:${1:\\<cursor-here>}}*"
    },
    "when": "editorTextFocus && !editorReadonly",
    "language": "typst"
  },
  {
    "key": "cmd+i",
    "command": "editor.action.insertSnippet",
    "args": {
      "snippet": "_${TM_SELECTED_TEXT:${1:\\<cursor-here>}}_"
    },
    "when": "editorTextFocus && !editorReadonly",
    "language": "typst"
  },
  {
    "key": "cmd+u",
    "command": "editor.action.insertSnippet",
    "args": {
      "snippet": "#text(underline: true)[${TM_SELECTED_TEXT:${1:\\<cursor-here>}}]"
    },
    "when": "editorTextFocus && !editorReadonly",
    "language": "typst"
  },
  {
    "key": "cmd+r",
    "command": "editor.action.insertSnippet",
    "args": {
      "snippet": "#text(fill: red)[${TM_SELECTED_TEXT:${1:\\<cursor-here>}}]"
    },
    "when": "editorTextFocus && !editorReadonly",
    "language": "typst"
  },

  // More keybindings...
  {
    "key": "cmd+[Minus]",
    "command": "editor.action.commentLine",
    "when": "editorTextFocus && !editorReadonly"
  },
  {
    "key": "alt+cmd+s",
    "command": "workbench.action.toggleUnifiedSidebarFromKeyboard",
    "when": "cursor.agentIdeUnification.enabled == true && !isAuxiliaryWindowFocusedContext"
  }
]
